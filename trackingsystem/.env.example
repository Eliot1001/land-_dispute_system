# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database (for Render PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/landdispute_db

# For local development (MySQL)
DB_ENGINE=django.db.backends.mysql
DB_NAME=landdispute_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306
