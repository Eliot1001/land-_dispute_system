# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# DATABASE_URL is for production (Render PostgreSQL) - leave unset locally
# so settings.py falls back to the DB_* vars below.
DATABASE_URL=

# Local development (PostgreSQL)
DB_NAME=landdispute_db
DB_USER=postgres
DB_PASSWORD=your_postgresql_password
DB_HOST=localhost
DB_PORT=5432

# Email (password reset codes) - Gmail SMTP with an App Password.
# Leave unset locally to just print emails to the console instead.
EMAIL_HOST_USER=youraddress@gmail.com
EMAIL_HOST_PASSWORD=your-16-character-app-password
DEFAULT_FROM_EMAIL=youraddress@gmail.com
